---
import Layout from '../../layouts/Layout.astro';
import FrozenLakeViz from '../FrozenLakeViz.jsx';
---


<Layout title="Simulador: Frozen Lake">
  <main style="padding: 40px 20px; background-color: #f8fafc; min-height: 100vh;">
    
    <div style="margin-bottom: 30px; text-align: center;">
      <h1 style="color: #1e293b; margin: 0; font-size: 28px;">Búsqueda No Informada</h1>
      <p style="color: #64748b; margin: 5px 0 0 0;">Entorno de Frozen Lake con BFS y DFS</p>
    </div>

    {/* ⚠️ CRUCIAL: Usa la directiva client:load */}
    <FrozenLakeViz client:load />

  </main>
</Layout>