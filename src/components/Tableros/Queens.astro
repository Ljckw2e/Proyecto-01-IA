---
// Queens.astro
// Este componente maneja la visualización del tablero de ajedrez y las 8 Reinas usando Mock Data.
---

<div class="queens-wrapper">
  <div id="q-grid-container" class="q-grid">
    {/* El tablero se generará dinámicamente con JS */}
  </div>
  
  <div class="status-bar">
    Estado: <span id="q-status">Esperando ejecución...</span>
  </div>
</div>

<script>
  /**
   * ==========================================
   * PARTE 1: SIMULACIÓN DE DATOS (MOCK DATA)
   * ==========================================
   * Simula la ejecución de Hill Climbing. 
   * Cada posición en el arreglo representa una columna (de 0 a 7), 
   * y el número es la fila donde está la reina [fila, columna].
   */
  const numQueens = 8;
  
  const mockSteps = [
    { state: [4, 5, 6, 3, 4, 5, 6, 3], attacks: 9, log: "Estado inicial aleatorio generado." },
    { state: [1, 5, 6, 3, 4, 5, 6, 3], attacks: 6, log: "Movida reina de col 0 a fila 1 (conflictos reducidos)." },
    { state: [1, 5, 2, 3, 4, 5, 6, 3], attacks: 4, log: "Movida reina de col 2 a fila 2." },
    { state: [1, 5, 2, 0, 4, 5, 6, 3], attacks: 2, log: "Movida reina de col 3 a fila 0." },
    { state: [1, 5, 2, 0, 4, 7, 6, 3], attacks: 1, log: "Movida reina de col 5 a fila 7." },
    { state: [1, 5, 2, 0, 4, 7, 3, 3], attacks: 2, log: "Intento fallido: El vecino aumenta conflictos. Fin por Máximo Local." }
  ];

  /**
   * ==========================================
   * PARTE 2: LÓGICA DE VISUALIZACIÓN
   * ==========================================
   */
  const gridContainer = document.getElementById('q-grid-container');
  const statusSpan = document.getElementById('q-status');

  let currentStepIndex = 0;
  let intervalId = null;

  // 1. Dibuja el tablero de ajedrez base (8x8)
  function crearTableroBase() {
    if (!gridContainer) return;
    gridContainer.innerHTML = '';
    
    gridContainer.style.gridTemplateColumns = `repeat(${numQueens}, 1fr)`;

    for (let r = 0; r < numQueens; r++) {
      for (let c = 0; c < numQueens; c++) {
        const cell = document.createElement('div');
        cell.className = 'q-tile';
        cell.id = `q-cell-${r}-${c}`;

        // Alternar colores de las casillas del ajedrez
        if ((r + c) % 2 === 1) {
          cell.classList.add('q-tile-dark');
        } else {
          cell.classList.add('q-tile-light');
        }

        gridContainer.appendChild(cell);
      }
    }
  }

  // 2. Renderiza el estado de las reinas en un paso específico
  function renderizarPaso(index) {
    if (!mockSteps[index]) return;
    
    const stepData = mockSteps[index];

    // Limpiar todas las coronas anteriores
    document.querySelectorAll('.q-tile').forEach(tile => {
      tile.innerHTML = '';
      tile.classList.remove('has-queen');
    });

    // Colocar las coronas en sus nuevas posiciones
    // stepData.state es un arreglo tipo [4, 5, 6...] -> col es el índice, r es el valor
    stepData.state.forEach((r, col) => {
      const cell = document.getElementById(`q-cell-${r}-${col}`);
      if (cell) {
        cell.classList.add('has-queen');
        cell.innerHTML = '<span class="queen-icon">👑</span>';
      }
    });

    // Actualizar barra de estado con los choques actuales
    if (statusSpan) {
      statusSpan.innerHTML = `Paso ${index + 1} (${stepData.attacks} choques): <span style="color:#fff">${stepData.log}</span>`;
    }
  }

  /**
   * ==========================================
   * PARTE 3: INTEGRACIÓN CON EVENTOS DEL SIDEBAR
   * ==========================================
   */
  
  window.addEventListener('reproducir_simulacion', () => {
    if (intervalId) return;
    
    if (currentStepIndex >= mockSteps.length - 1) {
        currentStepIndex = 0;
    }

    intervalId = setInterval(() => {
      if (currentStepIndex < mockSteps.length) {
        renderizarPaso(currentStepIndex);
        currentStepIndex++;
      } else {
        clearInterval(intervalId);
        intervalId = null;
        if (statusSpan) statusSpan.innerHTML += " - <span style='color:#5DCAA5'>FIN</span>";
      }
    }, 600);
  });

  window.addEventListener('siguiente_paso', () => {
    clearInterval(intervalId);
    intervalId = null;
    
    if (currentStepIndex < mockSteps.length - 1) {
        currentStepIndex++;
        renderizarPaso(currentStepIndex);
    }
  });

  window.addEventListener('anterior_paso', () => {
    clearInterval(intervalId);
    intervalId = null;
    
    if (currentStepIndex > 0) {
        currentStepIndex--;
        renderizarPaso(currentStepIndex);
    }
  });

  // Inicializar al cargar
  crearTableroBase();
  renderizarPaso(0);
</script>

<style>
  .queens-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    width: 100%;
    max-width: 450px;
  }

  .q-grid {
    display: grid;
    gap: 2px;
    width: 100%;
    aspect-ratio: 1;
    background-color: #222;
    padding: 4px;
    border-radius: 8px;
    box-shadow: 0 8px 16px rgba(0,0,0,0.2);
  }

  .q-tile {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    transition: background-color 0.2s ease;
  }

  /* Colores del tablero de ajedrez */
  .q-tile-light { background-color: #E3C193; }
  .q-tile-dark  { background-color: #B88B4A; }

  .queen-icon {
    font-size: 2.2rem;
    z-index: 2;
    animation: popIn 0.2s ease-out;
  }

  /* Efecto de resalte cuando hay una reina */
  .has-queen {
    box-shadow: inset 0 0 12px rgba(255, 255, 255, 0.4);
  }

  @keyframes popIn {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .status-bar {
    background: #444;
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 0.9rem;
    color: #ccc;
    width: 100%;
    text-align: center;
  }
  
  #q-status {
    color: #EF9F27;
    font-weight: bold;
  }
</style>